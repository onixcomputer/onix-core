#!/usr/bin/env bash

# Serialize nix-direnv evaluations across Zellij panes.
# Without this, every pane races to run `nix print-dev-env` simultaneously
# when the flake cache invalidates, causing nix store lock contention.
_nix_direnv_lock="${XDG_RUNTIME_DIR:-/tmp}/nix-direnv-$(echo "$PWD" | md5sum | cut -c1-16).lock"
if [[ -n $DIRENV_IN_ENVRC ]]; then
  exec 9>"$_nix_direnv_lock"
  flock 9
fi

# Don't fan out devshell builds to remote builders (aspen1, aspen2, desktop).
# The devshell is for the local machine — substituters are fine, but building
# on remotes just adds SSH overhead and store lock contention.
export NIX_CONFIG="builders ="
use flake
